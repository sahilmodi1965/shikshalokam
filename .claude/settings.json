{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "ShikshaLokam brain — a hive mind for content. Every contributor is equal; the brain operates autonomously for everyone. It may freely read/write its own content + config + voice + operating note (good content makes it smarter in-session). docs/** is the ONLY place it cannot hand-edit — that surface is 100% generated by tools/build_site.py, which is how drift stays structurally impossible. Hard safety rails remain: no force-push, no history rewrite, no rm/sudo/chmod, no network exfil, no secret/repo-admin access. SessionStart pulls + self-heals drift; SessionEnd rebuilds + commits + pushes (loud on failure).",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:origin main)",
      "Bash(git push:origin)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",
      "Bash(git tag:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git restore:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git config:*)",
      "Bash(git init:*)",
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(date)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(diff:*)",
      "Bash(find:*)",
      "Bash(sort:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(pdftotext:*)",
      "Bash(bash:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(gh run:*)",
      "Bash(gh pr:*)"
    ],
    "ask": [],
    "deny": [
      "Write(./docs/**)",
      "Edit(./docs/**)",

      "Bash(git push:--force*)",
      "Bash(git push:-f*)",
      "Bash(git reset:--hard*)",
      "Bash(git rebase:-i*)",
      "Bash(git branch:-D*)",
      "Bash(git branch:--delete*)",
      "Bash(git checkout:--orphan*)",
      "Bash(git clean:*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref:*)",

      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",

      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",

      "Bash(brew:install*)",
      "Bash(npm:install*)",
      "Bash(pip:install*)",
      "Bash(pip3:install*)",
      "Bash(pipx:*)",
      "Bash(gem:install*)",
      "Bash(cargo:install*)",
      "Bash(apt:*)",
      "Bash(apt-get:*)",

      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(terraform:*)",
      "Bash(gcloud:*)",
      "Bash(aws:*)",
      "Bash(az:*)",

      "Bash(gh auth:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo edit:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh secret:*)",
      "Bash(gh workflow:*)",
      "Bash(gh api:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__claude_ai_Gmail__create_draft",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/gmail_signature.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/tools/session_start.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/tools/session_end.sh\"",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
